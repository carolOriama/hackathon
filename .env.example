########################################################
# Environment Variables Example (no real secrets here)
########################################################

# Node environment
NODE_ENV=development

########################################################
# Frontend (Vite) – values exposed to the browser
# Prefix with VITE_ so Vite can access them via import.meta.env
########################################################

# Base URL for any backend/API server your frontend calls.
# Example: http://localhost:3000 or https://api.myapp.com
VITE_API_BASE_URL=http://localhost:3000

# Supabase client credentials (frontend-safe)
# Get these from your Supabase project's settings.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Public/publishable key used in the browser
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

########################################################
# Backend / Tooling (not exposed to the browser)
# Use these for servers, scripts, or local DB tools.
########################################################

# PostgreSQL connection string used by ORMs/migration tools (e.g. Drizzle).
# Example format (adjust host, db, and encoded password as needed):
# postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# Supabase service role key (server-side only, never ship to frontend).
# Use Project Settings > API > service_role (secret), NOT the anon key.
# If you get "permission denied for schema public", run the SQL in
# supabase/migrations/002_fix_public_schema_grants.sql in the SQL Editor.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

